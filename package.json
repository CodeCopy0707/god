{
  "name": "payment-matcher",
  "version": "1.0.0",
  "description": "Real-time payment order matching and Telegram alerting system",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --esm src/index.ts",
    "pm2": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop payment-matcher",
    "pm2:logs": "pm2 logs payment-matcher",
    "pm2:status": "pm2 status",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.1",
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2",
    "node-telegram-bot-api": "^0.66.0",
    "pg": "^8.20.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/node-telegram-bot-api": "^0.64.7",
    "rimraf": "^5.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
