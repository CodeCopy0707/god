# ============================================================
# Payment Order Matching System - Environment Variables
# Copy this file to .env and fill in your credentials
# ============================================================

# -- Supabase -------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# -- Telegram -------------------------------------------------
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_GROUP_ID=-1000000000000

# -- Database -------------------------------------------------
ACCOUNTS_TABLE=bank_data
TARGET_SUBAGENT_ID=your-subagent-uuid
MATCH_ALL_RECORDS=false

# -- Matching -------------------------------------------------
MIN_AMOUNT=9000

# -- Platform Tokens ------------------------------------------
# Each platform uses an `indiatoken` header unless configured otherwise.
GMPAY_TOKEN=
SUPERCOIN_TOKEN=
MILESPAY_TOKEN=
GTOD_TOKEN=
TIVRAPAY_TOKEN=
ZIPPAY_TOKEN=
FLOXYPAY_TOKEN=
LINKPAY_TOKEN=
VVPAY_TOKEN=
IPLPAY_TOKEN=

# -- Fetch & Timing ------------------------------------------
SEEN_RESET_INTERVAL_MS=300000
DB_REFRESH_INTERVAL_MS=60000
FETCH_PAGE_BATCH_SIZE=25
PLATFORM_MAX_PAGES_OVERRIDE=0

# -- Dashboard ------------------------------------------------
DASHBOARD_PORT=3010
DASHBOARD_ADMIN_ID=admin@example.com
DASHBOARD_ADMIN_PASSWORD=change-this-password
DASHBOARD_SESSION_SECRET=replace-with-long-random-secret
DASHBOARD_RECENT_ORDERS_LIMIT=250
DASHBOARD_RECENT_MATCHES_LIMIT=250
RUNTIME_EVENTS_TABLE=matcher_order_events
DISABLE_RUNTIME_EVENT_STORAGE=false

# -- Logging --------------------------------------------------
LOG_LEVEL=info
