# ============================================================
# Payment Order Matching System — Environment Variables
# Copy this file to .env and fill in your credentials
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_GROUP_ID=-1003542064587      # negative number for groups/supergroups

# ── Database ─────────────────────────────────────────────────
ACCOUNTS_TABLE=accounts               # name of the table in Supabase

# ── Matching ─────────────────────────────────────────────────
MIN_AMOUNT=5000                        # minimum order amount to process

# ── Timing (milliseconds) ────────────────────────────────────
SEEN_RESET_INTERVAL_MS=300000         # clear seen-orders cache every 5 min
DB_REFRESH_INTERVAL_MS=60000          # refresh accounts from DB every 60 s

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info                        # trace | debug | info | warn | error
